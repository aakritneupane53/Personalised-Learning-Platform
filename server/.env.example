# Postgres connection string (e.g. Neon). Must be reachable from Render.
NEON_DB=postgresql://user:password@host/dbname?sslmode=require

# Upstash Redis (REST API, not the TCP endpoint) — used for caching (JWT
# user lookups, /user-progress/summary) via @upstash/redis.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Primary Groq key + two independent fallback "deep" keys, tried in order
GROQ_API_KEY=
GROQ_DEEP_API_KEY1=
GROQ_DEEP_API_KEY2=

# Last-resort fallback provider for course/module content generation. Optional — if unset, the Gemini tier is skipped.
GEMINI_API_KEY=

# Comma-separated allowed frontend origin(s), e.g. https://your-app.vercel.app
CORS_ORIGIN=http://localhost:3000

# Render sets PORT automatically; NODE_ENV=production is set in the Dockerfile.
