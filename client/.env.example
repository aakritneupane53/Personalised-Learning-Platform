# Backend API base URL (see lib/axios.ts). Falls back to http://localhost:8000 if unset.
# Set this in your hosting provider's dashboard (Vercel/Netlify) for production —
# NEXT_PUBLIC_ vars are inlined at build time, so a local .env file has no effect on their build.
NEXT_PUBLIC_API_URL=<Your backend API URL here, e.g., https://personalised-learning-platform->>
